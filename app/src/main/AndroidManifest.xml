<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Cat verification needs the camera; storage stays internal so no media permissions. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature
        android:name="android.hardware.camera.any"
        android:required="false" />

    <!--
      Foreground-app detection (see AGENTS.md "Resolved"): we poll UsageStatsManager instead of
      running an AccessibilityService. PACKAGE_USAGE_STATS is an app-op with no runtime dialog — the
      user grants it in system Settings, so tools:ignore silences the "protected permission" check.
      The foreground service must keep running while the user is inside the app being watched.
    -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      Monitoring must come back by itself after a reboot: a screen-time blocker that silently stops
      enforcing is worse than none, because the user still believes they're covered.

      BOOT_COMPLETED only, and deliberately NOT LOCKED_BOOT_COMPLETED. The latter is delivered solely
      to android:directBootAware components, and ours can't be: the Room DB and the settings DataStore
      both live in credential-protected storage, which is unreadable until the user first unlocks.
      Nothing is lost by waiting — no app can be used on a locked device, so there is no screen time
      to track before the unlock that BOOT_COMPLETED already follows on FBE devices.
    -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Draws the block over the app whose limit was reached. Also what lets the service launch the
         camera from the background. Granted via a system Settings toggle, not a runtime dialog. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!--
      Android 11+ package visibility. The app picker only ever offers launchable apps, so we declare
      the LAUNCHER intent rather than requesting QUERY_ALL_PACKAGES — the narrower ask, and one that
      avoids Play Store sensitive-permission review.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:name=".UnPawseApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.UnPawse">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          "specialUse" is the honest type for screen-time monitoring: it isn't dataSync/mediaPlayback
          or any other predefined category. Shipping on Play with this type requires justifying the
          subtype below in the console.
        -->
        <service
            android:name=".service.UsageMonitorService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="screen_time_monitoring" />
        </service>

        <!--
          Lets the user share a capture out to other apps. The JPEGs are app-internal (not
          world-readable), so an ACTION_SEND needs a FileProvider content URI granted per-share.
          Authority matches the one built in shareCapture(). Paths are declared in res/xml/file_paths.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!--
          exported="true" is required despite the app never being the sender: BOOT_COMPLETED comes
          from the system, which counts as external. The receiver itself re-checks the action, and
          starting monitoring is not a privileged operation.
        -->
        <receiver
            android:name=".service.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>